                "targetCPUUtilizationPercentage": {
                    "default": 80,
                    "type": "integer"
                },
                "targetMemoryUtilizationPercentage": {
                    "default": 80,
                    "type": "integer"
                }
            }
        },
        "deploymentStrategy": {
            "type": "object",
            "properties": {
                "type": {
                    "default": "RollingUpdate",
                    "type": "string"
                }
            }
        },
        "env": {
