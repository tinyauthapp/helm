                            "matches": [
                                {
                                    "path": {
                                        "type": "PathPrefix",
                                        "value": "/"
                                    }
                                }
                            ]
                        }
                    ],
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "matches": {
                                "type": "array",
