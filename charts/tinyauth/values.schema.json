                "accessMode": {
                    "description": "Access mode for the PVC",
                    "default": "ReadWriteOnce",
                    "type": "string"
                },
                "annotations": {
                    "description": "Annotations to add to the PVC",
                    "default": {},
                    "type": "object"
                },
                "enabled": {
                    "description": "Enable persistent storage for SQLite session database",
                    "default": false,
                    "type": "boolean"
                },
                "mountPath": {
                    "description": "Mount path for the persistent volume where SQLite database will be stored",
                    "default": "/data",
                    "type": "string"
                },
                "size": {
                    "description": "Size of the PVC for SQLite database storage",
                    "default": "1Gi",
                    "type": "string"
                },
                "storageClass": {
                    "description": "StorageClass for the PVC. If not set, the default StorageClass will be used",
                    "default": "",
                    "type": "string"
                }
            }
